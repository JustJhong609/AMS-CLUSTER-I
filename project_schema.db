-- ==========================================
-- ALS Cluster I Mapping System - Validated Schema (App-Aligned)
-- Supabase / PostgreSQL
-- ==========================================

begin;

create extension if not exists pgcrypto;
create extension if not exists citext;
create extension if not exists pg_trgm;

-- ---------- ENUMS ----------
do $$ begin
  if not exists (select 1 from pg_type where typname = 'sex_enum') then
    create type sex_enum as enum ('Male', 'Female');
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'civil_status_enum') then
    create type civil_status_enum as enum ('Single', 'Married', 'Widow/er', 'Separated', 'Live-in');
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'yes_no_enum') then
    create type yes_no_enum as enum ('Yes', 'No');
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'family_role_enum') then
    create type family_role_enum as enum (
      'Head',
      'Spouse',
      'Daughter/Son',
      'Stepson/Stepdaughter',
      'Son-in-law/Daughter-in-law',
      'Grandson/Granddaughter',
      'Father/Mother',
      'Brother/Sister',
      'Uncle/Aunt',
      'Nephew/Niece',
      'Houseboy/Housegirl',
      'Others (Non-relative/Boarder)'
    );
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'occupation_type_enum') then
    create type occupation_type_enum as enum ('Government', 'Private', 'Self-employed', 'None');
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'employment_status_enum') then
    create type employment_status_enum as enum ('Regular', 'Contractual', 'Casual', 'JO');
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'pwd_type_enum') then
    create type pwd_type_enum as enum (
      'Partially Hearing Impaired',
      'Totally Hearing Impaired',
      'Partially Visually Impaired',
      'Totally Visually Impaired',
      'Physically Impaired',
      'W/ Special Needs',
      'Others (Please Specify)'
    );
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'transport_mode_enum') then
    create type transport_mode_enum as enum (
      'Walking',
      'Tricycle',
      'Habal-habal',
      'Jeepney',
      'Multicab',
      'Private Vehicle',
      'Bicycle'
    );
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'grade_level_enum') then
    create type grade_level_enum as enum (
      'G1 – G6 (Elementary)',
      '1st Year HS / Grade 7',
      '2nd Year HS / Grade 8',
      '3rd Year HS / Grade 9',
      '4th Year HS / Grade 10',
      'High School Graduate',
      'Grade 11 Vocational',
      'Senior HS Graduate'
    );
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'reason_not_attending_enum') then
    create type reason_not_attending_enum as enum (
      'Schools are very far',
      'No school within the barangay',
      'No regular transportation',
      'High cost of education',
      'Illness / Disability',
      'Housekeeping / Housework',
      'Employment / Looking for work',
      'Lack of personal interest',
      'Cannot cope with school work',
      'Others (Specify)'
    );
  end if;
end $$;

do $$ begin
  if not exists (select 1 from pg_type where typname = 'session_time_enum') then
    create type session_time_enum as enum (
      'Morning (8:00 AM – 12:00 PM)',
      'Afternoon (1:00 PM – 5:00 PM)',
      'Evening (6:00 PM – 9:00 PM)',
      'Weekends Only'
    );
  end if;
end $$;

-- ---------- PROFILE TABLE ----------
create table if not exists public.app_profiles (
  id uuid primary key references auth.users(id) on delete cascade,
  email citext unique,
  full_name text,
  role text not null default 'mapper' check (role in ('mapper', 'admin')),
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now()
);

-- ---------- LEARNERS TABLE (ALIGNED WITH FRONTEND PAYLOAD) ----------
drop table if exists public.learners cascade;

create table public.learners (
  id uuid primary key default gen_random_uuid(),
  legacy_local_id text unique,

  created_by uuid not null default auth.uid() references auth.users(id),
  updated_by uuid default auth.uid() references auth.users(id),
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),

  region text not null default 'Region X (Northern Mindanao)',
  division text not null default 'Bukidnon Cluster I',
  district text not null default 'ALS Cluster I Mapping Coverage',
  calendar_year int not null check (calendar_year between 2000 and 2100),
  mapped_by text not null,

  last_name text not null,
  first_name text not null,
  middle_name text not null default '',
  name_extension text,
  sex sex_enum not null,
  civil_status civil_status_enum not null,
  birthdate date not null,
  age int not null check (age between 0 and 130),
  mother_tongue text not null,
  is_ip boolean not null default false,
  ip_tribe text,
  religion text,
  is_4ps_member boolean not null default false,
  four_ps_or_ip text,
  is_pwd boolean not null default false,
  pwd_type pwd_type_enum,
  pwd_type_other text,

  municipality text not null check (municipality in ('Libona', 'Manolo Fortich', 'Baungon', 'Malitbog')),
  learner_district text not null,
  barangay text,
  barangay_other text,
  complete_address text not null,

  role_in_family family_role_enum not null,
  father_name text,
  mother_name text,
  guardian_name text,
  guardian_occupation text,

  school_name text,
  currently_studying yes_no_enum not null default 'No',
  last_grade_completed grade_level_enum,
  reason_for_not_attending reason_not_attending_enum,
  reason_for_not_attending_other text,

  is_blp boolean not null default false,
  occupation_type occupation_type_enum,
  employment_status employment_status_enum,
  monthly_income text,
  interested_in_als yes_no_enum not null default 'No',
  contact_number text,

  distance_km numeric(8,2) not null check (distance_km >= 0),
  travel_time text not null,
  transport_mode transport_mode_enum not null,
  preferred_session_time session_time_enum not null,
  date_mapped date not null,

  search_text tsvector generated always as (
    to_tsvector(
      'simple',
      coalesce(last_name,'') || ' ' ||
      coalesce(first_name,'') || ' ' ||
      coalesce(middle_name,'') || ' ' ||
      coalesce(municipality,'') || ' ' ||
      coalesce(learner_district,'') || ' ' ||
      coalesce(barangay,'') || ' ' ||
      coalesce(barangay_other,'') || ' ' ||
      coalesce(complete_address,'') || ' ' ||
      coalesce(contact_number,'')
    )
  ) stored,

  constraint chk_ip_tribe_required
    check (not is_ip or nullif(trim(coalesce(ip_tribe,'')), '') is not null),

  constraint chk_pwd_other_required
    check (
      pwd_type is distinct from 'Others (Please Specify)'::pwd_type_enum
      or nullif(trim(coalesce(pwd_type_other,'')), '') is not null
    ),

  constraint chk_reason_other
    check (
      reason_for_not_attending is distinct from 'Others (Specify)'::reason_not_attending_enum
      or nullif(trim(coalesce(reason_for_not_attending_other,'')), '') is not null
    ),

  constraint chk_reason_studying
    check (
      currently_studying = 'No'
      or reason_for_not_attending is null
    ),

  constraint chk_employment_required_when_occupied
    check (
      occupation_type is null
      or occupation_type = 'None'
      or employment_status is not null
    ),

  constraint chk_barangay_choice
    check (
      (nullif(trim(coalesce(barangay,'')), '') is not null and nullif(trim(coalesce(barangay_other,'')), '') is null)
      or
      (nullif(trim(coalesce(barangay,'')), '') is null and nullif(trim(coalesce(barangay_other,'')), '') is not null)
    )
);

-- ---------- TRIGGERS ----------
create or replace function public.fn_set_updated_at()
returns trigger
language plpgsql
as $$
begin
  new.updated_at = now();
  return new;
end;
$$;

create or replace function public.fn_set_updated_by()
returns trigger
language plpgsql
as $$
begin
  new.updated_by = auth.uid();
  return new;
end;
$$;

create or replace function public.fn_sync_age_from_birthdate()
returns trigger
language plpgsql
as $$
begin
  if new.birthdate is not null then
    new.age = extract(year from age(current_date, new.birthdate))::int;
  end if;
  return new;
end;
$$;

drop trigger if exists trg_profiles_updated_at on public.app_profiles;
create trigger trg_profiles_updated_at
before update on public.app_profiles
for each row
execute function public.fn_set_updated_at();

drop trigger if exists trg_learners_updated_at on public.learners;
create trigger trg_learners_updated_at
before update on public.learners
for each row
execute function public.fn_set_updated_at();

drop trigger if exists trg_learners_updated_by on public.learners;
create trigger trg_learners_updated_by
before update on public.learners
for each row
execute function public.fn_set_updated_by();

drop trigger if exists trg_learners_sync_age on public.learners;
create trigger trg_learners_sync_age
before insert or update of birthdate on public.learners
for each row
execute function public.fn_sync_age_from_birthdate();

create or replace function public.handle_new_user()
returns trigger
language plpgsql
security definer
set search_path = public
as $$
begin
  insert into public.app_profiles (id, email, full_name)
  values (
    new.id,
    new.email,
    coalesce(new.raw_user_meta_data->>'full_name', '')
  )
  on conflict (id) do update
  set
    email = excluded.email,
    full_name = excluded.full_name,
    updated_at = now();

  return new;
end;
$$;

drop trigger if exists on_auth_user_created on auth.users;
create trigger on_auth_user_created
after insert on auth.users
for each row
execute function public.handle_new_user();

-- ---------- INDEXES ----------
create index if not exists idx_learners_created_by on public.learners(created_by);
create index if not exists idx_learners_date_mapped on public.learners(date_mapped desc);
create index if not exists idx_learners_calendar_year on public.learners(calendar_year);
create index if not exists idx_learners_name on public.learners(last_name, first_name, middle_name);
create index if not exists idx_learners_municipality on public.learners(municipality);
create index if not exists idx_learners_district on public.learners(learner_district);
create index if not exists idx_learners_barangay on public.learners(barangay);
create index if not exists idx_learners_search_text on public.learners using gin(search_text);

-- ---------- RLS ----------
alter table public.app_profiles enable row level security;
alter table public.learners enable row level security;

drop policy if exists profiles_select_own on public.app_profiles;
create policy profiles_select_own
  on public.app_profiles
  for select
  to authenticated
  using (id = auth.uid());

drop policy if exists profiles_update_own on public.app_profiles;
create policy profiles_update_own
  on public.app_profiles
  for update
  to authenticated
  using (id = auth.uid())
  with check (id = auth.uid());

drop policy if exists learners_select_auth on public.learners;
create policy learners_select_auth
  on public.learners
  for select
  to authenticated
  using (true);

drop policy if exists learners_insert_auth on public.learners;
create policy learners_insert_auth
  on public.learners
  for insert
  to authenticated
  with check (auth.uid() is not null);

drop policy if exists learners_update_auth on public.learners;
create policy learners_update_auth
  on public.learners
  for update
  to authenticated
  using (created_by = auth.uid())
  with check (created_by = auth.uid());

drop policy if exists learners_delete_auth on public.learners;
create policy learners_delete_auth
  on public.learners
  for delete
  to authenticated
  using (created_by = auth.uid());

-- ---------- ANALYTICS VIEW ----------
create or replace view public.learner_analytics_summary as
select
  l.calendar_year,
  l.municipality,
  l.learner_district,
  coalesce(nullif(l.barangay, ''), l.barangay_other) as barangay,
  count(*) as total_learners,
  count(*) filter (where l.sex = 'Male') as male_count,
  count(*) filter (where l.sex = 'Female') as female_count,
  count(*) filter (where l.is_blp) as blp_count,
  count(*) filter (where l.is_4ps_member) as four_ps_count,
  count(*) filter (where l.is_ip) as ip_count,
  count(*) filter (where l.is_pwd) as pwd_count
from public.learners l
group by l.calendar_year, l.municipality, l.learner_district, coalesce(nullif(l.barangay, ''), l.barangay_other);

commit;
